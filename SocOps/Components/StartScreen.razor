<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gray-50">
    <div class="text-center max-w-md w-full">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Soc Ops</h1>
        <p class="text-lg text-gray-600 mb-8">Social Bingo</p>

        <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200 mb-8">
            <h2 class="font-semibold text-gray-800 mb-3">How to play</h2>
            <ul class="text-left text-gray-600 text-sm space-y-2">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-200">
            <h2 class="font-semibold text-gray-800 mb-4">Team Setup</h2>
            
            <div class="mb-4">
                <label class="block text-left text-sm font-medium text-gray-700 mb-1">
                    Team Name (Optional)
                </label>
                <input
                    type="text"
                    @bind="TeamName"
                    placeholder="e.g., The Padel Kings"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:border-accent" />
            </div>

            <div class="space-y-3 mb-6">
                <label class="block text-sm font-medium text-gray-700">
                    Player Names *
                </label>
                @for (int i = 0; i < 4; i++)
                {
                    <input
                        type="text"
                        @bind="PlayerNames[i]"
                        placeholder="@($"Player {i + 1}")"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-gray-900 focus:outline-none focus:border-accent" />
                }
            </div>

            <button
                @onclick="HandleStartGame"
                disabled="@(!IsFormValid())"
                class="w-full bg-accent text-white font-semibold py-3 px-6 rounded-lg text-lg disabled:opacity-50 disabled:cursor-not-allowed active:bg-accent-light transition-colors">
                Start Game
            </button>

            @if (!IsFormValid() && HasAttemptedStart)
            {
                <p class="text-red-600 text-sm mt-2">All player names are required</p>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<Team> OnStart { get; set; }

    private string TeamName = "Team";
    private string[] PlayerNames = new[] { "", "", "", "" };
    private bool HasAttemptedStart = false;

    private bool IsFormValid()
    {
        return PlayerNames.All(name => !string.IsNullOrWhiteSpace(name));
    }

    private async Task HandleStartGame()
    {
        HasAttemptedStart = true;
        
        if (!IsFormValid())
            return;

        var team = new Team
        {
            Name = string.IsNullOrWhiteSpace(TeamName) ? "Team" : TeamName,
            Players = PlayerNames
                .Select(name => new Player { Name = name.Trim() })
                .ToList()
        };

        await OnStart.InvokeAsync(team);
    }
}

