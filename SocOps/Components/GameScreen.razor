@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-50">
    <!-- Header -->
    <header class="flex items-center justify-between p-3 bg-white border-b border-gray-200">
        <button
            @onclick="OnReset"
            class="text-gray-500 text-sm px-3 py-1.5 rounded active:bg-gray-100">
            ← Back
        </button>
        <h1 class="font-bold text-gray-900">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Team Info Banner -->
    @if (Team != null && Team.Players.Count > 0)
    {
        <div class="bg-blue-50 border-b border-blue-200 p-3">
            <p class="text-center font-semibold text-gray-900 text-sm mb-1">@Team.Name</p>
            <div class="flex flex-wrap justify-center gap-2 text-xs">
                @foreach (var player in Team.Players)
                {
                    <span class="bg-white text-gray-700 px-2 py-1 rounded border border-gray-300">@player.Name</span>
                }
            </div>
        </div>
    }

    <!-- Instructions -->
    <p class="text-center text-gray-500 text-sm py-2 px-4">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-amber-100 text-amber-800 text-center py-2 font-semibold text-sm">
            🎉 BINGO! You got a line!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }

    [Parameter]
    public Team? Team { get; set; }
}
